# --- Обязательно для запуска MCP (подпись CartMandate, HS256 JWT) ---
SBER_MANDATE_SIGNING_SECRET=

# --- Профиль мерчанта (get_merchant_info); замените тестовые значения перед проверкой у Сбера ---
SBER_MERCHANT_NAME=
SBER_MERCHANT_WEBSITE=https://example.com
SBER_MERCHANT_DESCRIPTION=
SBER_CONTACT_PHONE=
SBER_CONTACT_EMAIL=

# JSON-массивы (опционально): категории, способы доставки, опции оплаты
# SBER_MAIN_CATEGORIES_JSON=["excursions","tickets"]
# SBER_DELIVERY_METHODS_JSON=[]
# SBER_PAYMENT_OPTIONS_JSON={"online":{"supported":true,"methods":["card","sberpay"]},"courier":{"supported":false,"methods":[]},"pickup":{"supported":false,"methods":[]}}

SBER_DELIVERY_REGIONS=Россия
SBER_SBERID_SUPPORTED=true
SBER_SBERPAY_SUPPORTED=true
SBER_DIGITAL_DELIVERY_ONLY=true

# База для paymentUrl в create_order (подставьте свой боевой URL оплаты)
SBER_PAYMENT_URL_BASE=https://example.com/pay

# SKU в get_skus: префикс + show_id Qtickets; остаток из API или fallback
SBER_SKU_ID_PREFIX=sber_sku_show_
SBER_FALLBACK_STOCK_QUANTITY=100

# Срок JWT мандата (строка для jose, например 2h)
SBER_MANDATE_JWT_EXPIRES_IN=2h

# Локальная отладка: не требовать все поля clientInfo (не для приёмки Сбера)
# SBER_RELAX_CLIENT_INFO=true

# Проверять, что clientInfoToken похож на JWT (три части через точку)
# SBER_VERIFY_CLIENT_INFO_JWT_SHAPE=false

# Дополнительные tools Qtickets (не входят в спецификацию mcp-integration)
# MCP_REGISTER_QTICKETS_TOOLS=false

# --- Qtickets REST (для get_skus с реальным остатком и для диагностических tools) ---
QTICKETS_API_TOKEN=
QTICKETS_API_BASE_URL=https://qtickets.ru/api/rest/v1
QTICKETS_API_AUTH_HEADER_NAME=authorization
QTICKETS_API_AUTH_SCHEME=Bearer
QTICKETS_API_REQUEST_TIMEOUT_MS=20000

QTICKETS_CHECKOUT_MODE=redirect_widget
QTICKETS_PUBLIC_WIDGET_BASE_URL=https://qtickets.ru
QTICKETS_ENABLE_CREATE_ORDER=false

MCP_HEALTH_PORT=8790
