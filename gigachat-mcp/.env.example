# Обязательно: тот же токен, что и для REST в кабинете Qtickets (Настройки → Основное).
QTICKETS_API_TOKEN=

# База REST (если у организатора другой хост — замените).
QTICKETS_API_BASE_URL=https://qtickets.ru/api/rest/v1

QTICKETS_API_AUTH_HEADER_NAME=authorization
QTICKETS_API_AUTH_SCHEME=Bearer
QTICKETS_API_REQUEST_TIMEOUT_MS=20000

# Режим подсказки оплаты для инструмента qtickets_checkout_hint:
# redirect_widget — основной сценарий: дать пользователю siteUrl виджета Qtickets
# payment_url_after_create — после программного создания заказа ожидать payment_url (нужен POST /orders)
QTICKETS_CHECKOUT_MODE=redirect_widget

# Публичный базовый URL виджета (если в ответах API относительные пути).
QTICKETS_PUBLIC_WIDGET_BASE_URL=https://qtickets.ru

# Опасная операция: включайте только после подтверждения контракта у поддержки Qtickets.
QTICKETS_ENABLE_CREATE_ORDER=false

# Порт процесса health (npm run start:http); не путать с MCP stdio.
MCP_HEALTH_PORT=8790
