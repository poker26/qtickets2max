# Обязательно (организатор Qtickets)
QTICKETS_API_TOKEN=

QTICKETS_API_BASE_URL=https://qtickets.ru/api/rest/v1
QTICKETS_API_AUTH_HEADER_NAME=authorization
QTICKETS_API_AUTH_SCHEME=Bearer
QTICKETS_API_REQUEST_TIMEOUT_MS=20000

QTICKETS_PUBLIC_WIDGET_BASE_URL=https://qtickets.ru

# Создание заказа через API — только после согласования с Qtickets
QTICKETS_AGENT_ENABLE_CREATE_ORDER=false
