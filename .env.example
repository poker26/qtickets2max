PORT=8787
LOG_LEVEL=info

# Optional token to protect webhook endpoint.
# If set, request must contain one of headers:
# x-qtickets-secret OR x-webhook-secret OR authorization: Bearer <token>
QTICKETS_WEBHOOK_SECRET=
# Qtickets API: order details (optional; default is official REST URL with {orderId}).
# QTICKETS_ORDER_DETAILS_URL_TEMPLATE=https://qtickets.ru/api/rest/v1/orders/{orderId}
# Required for webhooks to work (Qtickets REST order fetch). Service starts without it.
QTICKETS_API_TOKEN=
QTICKETS_API_AUTH_HEADER_NAME=authorization
QTICKETS_API_AUTH_SCHEME=Bearer
QTICKETS_API_REQUEST_TIMEOUT_MS=10000

# Max Bot API credentials (same format as tg2max).
MAX_BOT_TOKEN=
MAX_TARGET_CHAT_ID=-72889036398770
MAX_API_BASE_URL=https://platform-api.max.ru
MAX_MESSAGE_PREFIX=[MiniFarm]
MAX_REQUEST_TIMEOUT_MS=10000
